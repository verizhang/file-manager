# =========================================================
# APP
# =========================================================

APP_NAME=file-manager
APP_ENV=development
APP_PORT=8080
APP_DEBUG=true

# =========================================================
# DATABASE
# =========================================================

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=file_manager
DB_SSLMODE=false

# =========================================================
# S3 / MINIO
# =========================================================

S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=file-manager
S3_USE_SSL=false
S3_REGION=us-east-1

# =========================================================
# PRESIGNED URL
# =========================================================

PRESIGNED_UPLOAD_EXPIRE_MINUTES=15
PRESIGNED_DOWNLOAD_EXPIRE_MINUTES=30

# =========================================================
# MULTIPART
# =========================================================

# minimum multipart upload size
# default: 5MB
MULTIPART_PART_SIZE=5242880

# =========================================================
# FILE VALIDATION
# =========================================================

# maximum upload file size
# default: 100MB
MAX_FILE_SIZE=104857600

# comma separated mime types
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf,video/mp4

# =========================================================
# CLAMAV
# =========================================================

CLAMAV_ENABLED=false
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# =========================================================
# RATE LIMIT
# =========================================================

RATE_LIMIT_REQUEST=100
RATE_LIMIT_DURATION=1m